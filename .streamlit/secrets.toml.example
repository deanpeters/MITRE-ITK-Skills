# For Streamlit Community Cloud deployment only.
# Copy to .streamlit/secrets.toml and fill in your key before deploying,
# OR add ANTHROPIC_API_KEY directly in the Streamlit Cloud "Secrets" settings UI.
#
# For local development: set ANTHROPIC_API_KEY (or OPENAI_API_KEY) as an
# environment variable instead. The app reads from os.environ — never from
# user input in the UI.
#
# secrets.toml is gitignored and never committed.

ANTHROPIC_API_KEY = "sk-ant-..."
